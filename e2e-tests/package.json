{
  "name": "hospital-report-e2e",
  "version": "1.0.0",
  "private": true,
  "description": "医院体检报告管理系统 Playwright AI 自动化测试",
  "scripts": {
    "test:smoke": "playwright test --project=smoke-chromium",
    "test:regression": "playwright test --project=regression-chromium --project=regression-firefox",
    "test:all": "playwright test",
    "test:list": "playwright test --list",
    "report:html": "playwright show-report",
    "report:allure": "allure generate allure-results -o allure-report --clean && allure open allure-report",
    "ai:generate": "npx tsx ai/cli.ts generate",
    "ai:modify": "npx tsx ai/cli.ts modify",
    "ai:extend": "npx tsx ai/cli.ts extend",
    "ui": "cd dashboard && npx tsx server/index.ts",
    "ui:install": "cd dashboard && npm install"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/node": "^20.11.0",
    "allure-commandline": "^2.27.0",
    "allure-playwright": "^3.0.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.0",
    "mysql2": "^3.9.0",
    "ts-node": "^10.9.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "cors": "^2.8.6",
    "express": "^5.2.1"
  }
}
